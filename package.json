{
  "name": "clawguard",
  "version": "1.0.0",
  "private": true,
  "description": "OpenClaw configuration management tool",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter clawguard dev",
    "build": "node scripts/build.js",
    "build:cli": "pnpm --filter clawguard build",
    "build:core": "pnpm --filter @core/clawguard build",
    "build:gateway": "pnpm --filter @clawguard/gateway build",
    "gateway": "pnpm --filter @clawguard/gateway start",
    "build:web": "pnpm --filter @clawguard/web build",
    "web": "pnpm --filter @clawguard/web dev",
    "test": "vitest --run",
    "test:cli": "vitest --filter=@cli/clawguard --run",
    "test:core": "vitest --filter=@core/clawguard --run",
    "test:e2e": "playwright test --run",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "fs-extra": "^11.2.0",
    "hono": "^4.12.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.5",
    "@types/tar": "^7.0.87",
    "eslint": "^8.57.0",
    "playwright": "^1.42.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
